<%- include('partials/header') %>

<h1>Quản lý sản phẩm</h1>

<form action="/admin/products/add" method="POST" enctype="multipart/form-data" class="admin-form">
  <h2>Thêm sản phẩm mới</h2>
  <label>
    Danh mục
    <select name="category_id" required>
      <% categories.forEach(function(cat) { %>
        <option value="<%= cat.id %>"><%= cat.name %></option>
      <% }); %>
    </select>
  </label>
  <label>
    Tên sản phẩm
    <input type="text" name="name" required />
  </label>
  <label>
    Thương hiệu
    <input type="text" name="brand" />
  </label>
  <label>
    Mô tả
    <input type="text" name="description" />
  </label>
  <label>
    Giá bán (đ)
    <input type="number" name="price" min="0" step="1000" required />
  </label>
  <label>
    Giá gốc (đ)
    <input type="number" name="original_price" min="0" step="1000" />
  </label>
  <label>
    Link affiliate (VD: link Shopee/Lazada, để trống nếu không có)
    <input type="text" name="affiliate_url" placeholder="https://shopee.vn/..." />
  </label>
  <label>
    Tải ảnh lên (ưu tiên nếu chọn)
    <input type="file" name="imageFile" accept="image/*" />
  </label>
  <label>
    Hoặc dán đường dẫn ảnh
    <input type="text" name="image" placeholder="/img/products/default.svg" />
  </label>
  <label>
    Số lượng kho
    <input type="number" name="stock" min="0" required />
  </label>

  <h3>Thông số kỹ thuật</h3>
  <div class="spec-rows">
    <div class="spec-row">
      <input type="text" name="specKey" placeholder="Tên thông số (VD: Màn hình)" />
      <input type="text" name="specValue" placeholder="Giá trị (VD: 50 inch 4K)" />
    </div>
  </div>
  <button type="button" class="btn-secondary" onclick="addSpecRow(this)">+ Thêm thông số</button>

  <button type="submit" class="btn">Thêm sản phẩm</button>
</form>

<h2>Danh sách sản phẩm</h2>
<table class="cart-table">
  <thead>
    <tr>
      <th>Ảnh</th>
      <th>Tên</th>
      <th>Danh mục</th>
      <th>Giá</th>
      <th>Kho</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% products.forEach(function(product) { %>
      <tr>
        <td><img src="<%= product.image %>" alt="" class="admin-thumb" /></td>
        <td><%= product.name %></td>
        <td><%= product.category_name %></td>
        <td><%= product.price.toLocaleString('vi-VN') %>đ</td>
        <td><%= product.stock %></td>
        <td>
          <a href="/admin/products/edit/<%= product.id %>" class="btn-small">Sửa</a>
          <form action="/admin/products/delete" method="POST" class="inline-form">
            <input type="hidden" name="productId" value="<%= product.id %>" />
            <button type="submit" class="link-button">Xóa</button>
          </form>
        </td>
      </tr>
    <% }); %>
  </tbody>
</table>

<script>
  function addSpecRow(btn) {
    const container = btn.previousElementSibling;
    const row = document.createElement('div');
    row.className = 'spec-row';
    row.innerHTML =
      '<input type="text" name="specKey" placeholder="Tên thông số" />' +
      '<input type="text" name="specValue" placeholder="Giá trị" />' +
      '<button type="button" onclick="this.parentElement.remove()">×</button>';
    container.appendChild(row);
  }
</script>

<%- include('partials/footer') %>
